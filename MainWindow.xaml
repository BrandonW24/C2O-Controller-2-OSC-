<Window x:Class="C2O.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CTRL 2 OSC" Height="850" Width="950"
        Background="#3C444E" Foreground="White"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Content="{TemplateBinding Header}" 
                                          Cursor="Hand"
                                          Background="#2F353D"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,10">
                                            <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite" Content="{TemplateBinding Content}" Visibility="Collapsed" Margin="{TemplateBinding Padding}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl Background="#3C444E" BorderBrush="#2C3239" Foreground="White">
            
            <TabItem Header="About C2O">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20,30,30">
                        <TextBlock Text="Controller 2 OSC (C2O)" Foreground="#DFBB3F" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="C# Edition V3.0" Foreground="#717171" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,10" LineHeight="20">
                            C2O is a lightweight, GUI-driven application designed to seamlessly bridge the gap between physical hardware and digital environments. It reads real-time data from connected USB steering wheels, Bluetooth gamepads, joysticks, and keyboards. Capturing everything from continuous analog axes (like pedals and throttles) to discrete button presses and D-pad movements.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,10" LineHeight="20">
                            The application translates and broadcasts these inputs over a local network using the Open Sound Control (OSC) protocol, ensuring extremely low-latency communication without the need for heavy middleware.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,20" LineHeight="20">
                            C2O was developed as a versatile solution for mapping physical simulation hardware to Massive Loop.
                        </TextBlock>
                        <TextBlock Text="Programmed by Brandon Withington" Foreground="#33FF00" FontSize="14" FontWeight="Bold" Margin="0,0,0,30"/>

                        <TextBlock Text="How to Use" Foreground="#DFBB3F" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,10">
                            <Run FontWeight="Bold" Foreground="#DFBB3F">1. Plug in your device:</Run> Ensure your USB steering wheel or controller is connected to your PC.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,5">
                            <Run FontWeight="Bold" Foreground="#DFBB3F">2. Configure the Settings:</Run>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="20,0,0,5">
                            <Run FontWeight="Bold">Target IP:</Run> The IP address of the receiving machine.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="20,0,0,5">
                            <Run FontWeight="Bold">Target Port (Send):</Run> The network port your receiving application is listening to.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="20,0,0,5">
                            <Run FontWeight="Bold">Listen Port (FFB In):</Run> The port C2O listens on for incoming OSC Force Feedback commands.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="20,0,0,10">
                            <Run FontWeight="Bold">Base OSC Address:</Run> The default OSC endpoint you want to broadcast to (unless overridden by a custom address in the input settings).
                        </TextBlock>
                        
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,30">
                            <Run FontWeight="Bold" Foreground="#DFBB3F">3. Start Streaming:</Run> Click the Start Streaming button in the Output Settings tab.
                        </TextBlock>

                        <TextBlock Text="Input Settings &amp; Math Curves" Foreground="#DFBB3F" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,5">
                            <Run FontWeight="Bold">Deadzone:</Run> Allows you to set a center threshold that ignores slight resting inputs (like stick drift). The output will scale smoothly past the deadzone.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,5">
                            <Run FontWeight="Bold">Sensitivity:</Run> Acts as a multiplier. If set to 2.0, moving an axis halfway will output the maximum 1.0 value.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,5">
                            <Run FontWeight="Bold">Smooth (EMA):</Run> Exponential Moving Average. Adds a weighted delay to smooth out jittery or noisy potentiometers on pedals and throttles.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,30">
                            <Run FontWeight="Bold">Custom Addresses (Addr):</Run> You can override the base OSC address on a per-axis, per-button, or per-key basis. If left blank, it defaults to the Base OSC Address.
                        </TextBlock>

                        <TextBlock Text="OSC Payload Formats" Foreground="#DFBB3F" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Background="#2F353D" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Outgoing Inputs" Foreground="#DFBB3F" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="[Address] &quot;axis&quot; [Mapped ID] [Float Value]"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="[Address] &quot;button&quot; [Mapped ID] [Int Value (0/1)]"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="[Address] &quot;hat&quot; [Mapped ID] [Int X] [Int Y]"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,10" Text="[Address] &quot;keyboard&quot; [Mapped ID] [Int Value (0/1)]"/>

                                <TextBlock Text="Incoming Force Feedback (FFB)" Foreground="#DFBB3F" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/ffb/spring [Float 0-100]  -> Adjusts centering resistance"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/ffb/damper [Float 0-100]  -> Adjusts dynamic wheel weight"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/ffb/friction [Float 0-100]-> Adjusts static friction"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Output Settings">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox BorderThickness="0" Padding="15">
                        <GroupBox.Header>
                            <TextBlock Text="OSC Targeting &amp; Listening" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                        </GroupBox.Header>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Target IP:" Grid.Row="0" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TargetIpEntry" Text="127.0.0.1" Grid.Row="0" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>

                            <TextBlock Text="Target Port (Send):" Grid.Row="1" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TargetPortEntry" Text="4041" Grid.Row="1" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>

                            <TextBlock Text="Listen Port (FFB In):" Grid.Row="2" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="ListenPortEntry" Text="4042" Grid.Row="2" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>

                            <TextBlock Text="Base OSC Address:" Grid.Row="3" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="BaseAddrEntry" Text="/wheel/input" Grid.Row="3" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>
                        </Grid>
                    </GroupBox>

                    <Grid Grid.Row="1" Margin="0,15,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <Button x:Name="BtnToggleStream" Content="Start Streaming" Width="150" Height="35" Background="#28A745" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnToggleStream_Click"/>
                            <Button x:Name="BtnClearLog" Content="Clear Log" Width="100" Height="35" Margin="10,0,0,0" Background="#CC2900" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnClearLog_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock Text="Output Style:" Foreground="#DFBB3F" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            <RadioButton x:Name="RadioScroll" Content="Scrolling Log" IsChecked="True" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center" Checked="OutputStyle_Changed"/>
                            <RadioButton x:Name="RadioInPlace" Content="In-Place Dashboard" Foreground="White" VerticalAlignment="Center" Checked="OutputStyle_Changed"/>
                        </StackPanel>
                        
                        <Image x:Name="StatusIcon" Grid.Column="3" Width="36" Height="36" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBox x:Name="LogArea" Grid.Row="2" Background="#2F353D" Foreground="#33FF00" FontFamily="Consolas" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" BorderBrush="#717171" Padding="10"/>
                </Grid>
            </TabItem>

            <TabItem Header="Input Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        
                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Profile Management" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Active Profile:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="ProfileDropdown" Width="200" Background="#717171" Foreground="#2F353D" FontSize="14" BorderThickness="0" Padding="5" SelectionChanged="ProfileDropdown_SelectionChanged">
                                        <ComboBox.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#717171" />
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2F353D" />
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                        </ComboBox.Resources>
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#717171"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding" Value="5"/>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                    
                                    <Button x:Name="BtnDeleteProfile" Content="Delete Profile" Width="110" Margin="10,0,0,0" Background="#9C0E0E" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnDeleteProfile_Click"/>
                                    <Button x:Name="BtnSaveConfig" Content="Save Configs Now" Width="130" Margin="10,0,0,0" Background="#0052CC" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnSaveConfig_Click"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBox x:Name="NewProfileNameEntry" Width="200" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>
                                    <Button x:Name="BtnNewProfile" Content="Clone to New Profile" Width="150" Margin="10,0,0,0" Background="#009952" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnNewProfile_Click"/>
                                    
                                    <Border Width="1" Background="#717171" Margin="20,0,20,0"/>
                                    
                                    <Button x:Name="BtnImportProfile" Content="Import .json" Width="100" Margin="0,0,10,0" Background="#2F353D" Foreground="#DFBB3F" BorderThickness="0" FontWeight="Bold" Click="BtnImportProfile_Click"/>
                                    <Button x:Name="BtnExportProfile" Content="Export .json" Width="100" Background="#2F353D" Foreground="#DFBB3F" BorderThickness="0" FontWeight="Bold" Click="BtnExportProfile_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Input Device" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <ComboBox x:Name="DeviceDropdown" Width="250" Background="#717171" Foreground="#2F353D" FontSize="14" BorderThickness="0" Padding="5">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#717171" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2F353D" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    </ComboBox.Resources>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Background" Value="#717171"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Padding" Value="5"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                                
                                <Button x:Name="BtnAddDevice" Content="Add Device" Width="100" Margin="10,0,0,0" Background="#009952" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnAddDevice_Click"/>
                                <Button x:Name="BtnClearDevices" Content="Clear Devices" Width="100" Margin="10,0,0,0" Background="#9C0E0E" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnClearDevices_Click"/>
                                <Button Content="Refresh" Width="80" Margin="10,0,0,0" Background="#0052CC" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnRefresh_Click"/>
                            </StackPanel>
                        </Expander>
                        
                        <StackPanel x:Name="DynamicSettingsPanel" Margin="0,0,0,0"/>
                        
                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Global Keyboard Mapping" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <WrapPanel x:Name="KeyboardSettingsPanel" Margin="0,10,0,0"/>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>